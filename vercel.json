{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "/api/main.py"
    },
    {
      "source": "/api/generate-quiz",
      "destination": "/api/main.py"
    },
    {
      "source": "/api/chat",
      "destination": "/api/main.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}