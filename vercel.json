{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/main.py"
    },

    {
      "source": "/api/chat",
      "destination": "/api/main.py"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/server.js"
    },
    {
      "source": "/((?!assets|favicon|icons|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}